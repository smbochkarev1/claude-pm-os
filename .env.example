# PM OS environment. Copy to .env and fill in. .env is git-ignored — never commit it.
# The commands and workers read these; nothing secret lives in committed config.

# --- LLM (shipped adapter: adapters.llm:HttpLLM) ---------------------------
PM_OS_LLM_PROVIDER=anthropic          # anthropic | openai
PM_OS_LLM_API_KEY=                    # your API key
PM_OS_LLM_BASE_URL=                   # optional: override endpoint / gateway
PM_OS_LLM_MODEL=                      # optional: default model id

# --- Notifier (shipped adapter: adapters.notifier_telegram:TelegramNotifier)
NOTIFIER_BOT_TOKEN=                   # bot token from @BotFather (or Slack webhook, etc.)
NOTIFIER_CHAT_ID=                     # your DM = positive, group = negative

# --- Spreadsheet (shipped adapter: adapters.spreadsheet_gspread:GspreadSpreadsheet)
PM_OS_GSPREAD_TOKEN=~/.config/pm-os/google_token.json   # OAuth token json (spreadsheets+drive)

# --- Calendar (working adapter: adapters.calendar_google:GoogleCalendar) ----
# Pick ONE auth path. Both are google-auth, scope calendar.readonly.
GOOGLE_TOKEN_JSON=                    # path to an OAuth *user* token json (authorized_user format)
GOOGLE_CREDENTIALS_JSON=              # OR path to a *service account* key json
GOOGLE_CALENDAR_SUBJECT=              # service-account only: mailbox to impersonate (domain-wide delegation)
GOOGLE_CALENDAR_ID=primary           # which calendar to read
GOOGLE_CALENDAR_TIMEZONE=            # optional IANA tz for the query window (default: UTC)

# --- Transcripts (working adapter: adapters.transcript_zoom:ZoomTranscript) -
# Zoom Server-to-Server OAuth app (scope: cloud_recording:read:list_recording_files)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- Your other stack adapters (implement from adapters/stubs/*) ------------
TRACKER_TOKEN=                        # Jira/Linear/GitHub/… token, used by your tracker adapter
TRACKER_URL_PREFIX=                   # e.g. https://your-jira/browse/
CHAT_TOKEN=                           # Slack/Telegram token, used by your chat adapter

# --- Backlog target + source sheet ids (referenced by backlog_sources.yaml) -
BACKLOG_TARGET_SHEET_ID=
SHEET_GROWTH_ID=
SHEET_PAYMENTS_ID=

# --- Misc ------------------------------------------------------------------
PM_OS_HOME=                           # absolute repo path (workers/launchd use it)
PM_OS_METRICS_FRESHNESS_MIN=180       # metrics_watch: stale-data alarm threshold (minutes)
